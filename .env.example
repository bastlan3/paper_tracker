# === LLM for summaries ===
# Default: Mistral (free Experiment plan, no credit card needed)
# Alternatives: "anthropic" or "openai"
LLM_PROVIDER=mistral
MISTRAL_API_KEY=your-mistral-api-key
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# === Semantic Scholar API (optional) ===
# Free key for higher rate limits: https://www.semanticscholar.org/product/api
# Without key: 100 req/5 min.  With key: 1000 req/min.
# SEMANTIC_SCHOLAR_API_KEY=your-key-here

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# === Voxtral TTS (optional) ===
# Sends an audio summary after each paper's text message.
# Requires MISTRAL_API_KEY. Pricing: $0.016 per 1,000 characters.
# Voices: neutral_female, neutral_male, casual_female, casual_male, cheerful_female
# TELEGRAM_AUDIO=true
# VOXTRAL_VOICE_ID=neutral_female

# === Email (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_TO=your-email@gmail.com

# === App Config ===
SIMILARITY_THRESHOLD=0.45
DAILY_DIGEST_HOUR=9
WEEKLY_UMAP_DAY=monday
DATABASE_URL=sqlite:///data/ebm_tracker.db
